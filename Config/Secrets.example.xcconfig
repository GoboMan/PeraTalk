//
// このファイルを Secrets.xcconfig にコピーして実値を設定してください。
//   cp Config/Secrets.example.xcconfig Config/Secrets.xcconfig
//
// SUPABASE_URL … Dashboard → Settings → API の Project URL
// SUPABASE_PUBLISHABLE_KEY … Settings → API Keys の Publishable key（sb_publishable_...）
//
// 値にスペースや記号がある場合もダブルクォートで囲んでください。
//

SUPABASE_URL = "https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY = "YOUR_PUBLISHABLE_KEY"
