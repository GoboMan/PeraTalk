//
// Supabase（クライアント用・現行の API Keys 方式）
// - SUPABASE_REST_HOST … Dashboard の Project URL に対応する **ホスト名のみ**（例: zzzz.supabase.co）
//    ※ xcconfig と Info.plist で `https://…` を展開すると `//` がコメント扱いになり壊れるため、スキームは載せない。
// - SUPABASE_PUBLISHABLE_KEY … Settings → API Keys の Publishable key（sb_publishable_…）
// Secret keys（sb_secret_...）／service_role はクライアントに置かないこと。
//
// Sign in with Apple: Dashboard の Apple プロバイダ「Client IDs」にネイティブの Bundle ID を含める（Secrets.example.xcconfig の注記を参照）。
//
// Secrets.xcconfig を置いた場合のみ上書きされる（未定義時は直下の開発用デフォルトが使われる）。
// 別プロジェクトへの切替: Secrets.example.xcconfig を Config/Secrets.xcconfig にコピーして編集してください。
//

// URL に // が含まれないように **ホスト名のみ**書くこと（末尾スラッシュなし）。

SUPABASE_REST_HOST = zbnwaawfvhjrbrfobbvw.supabase.co
SUPABASE_PUBLISHABLE_KEY = sb_publishable_SdEdr2cotYZPeFuED4I5iQ_WLHaRj62

#include? "Secrets.xcconfig"

// 値は AppAuthInfo.plist の $(…) から Bundle に載る。INFOPLIST_KEY_* は任意キーに効かないため使わない。
